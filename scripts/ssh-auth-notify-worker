#!/usr/bin/env bash
set -Eeuo pipefail

CONFIG_FILE="${SSH_AUTH_NOTIFY_CONFIG:-/etc/ssh-auth-notify/env}"
SENDER="${SSH_AUTH_NOTIFY_SENDER:-/opt/ssh-auth-notify/scripts/ssh-auth-notify-send}"

log_debug() {
  if [[ "${SSH_AUTH_NOTIFY_DEBUG:-0}" == "1" ]]; then
    printf '[ssh-auth-notify-worker] %s\n' "$*" >&2
  fi
}

load_config() {
  if [[ -f "${CONFIG_FILE}" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "${CONFIG_FILE}"
    set +a
  fi
}

csv_contains() {
  local csv="${1:-}" needle="${2:-}" old_ifs item
  [[ -n "${csv}" && -n "${needle}" ]] || return 1
  old_ifs="${IFS}"
  IFS=',' read -r -a items <<<"${csv}"
  IFS="${old_ifs}"
  for item in "${items[@]}"; do
    item="${item//[[:space:]]/}"
    [[ "${item}" == "${needle}" ]] && return 0
  done
  return 1
}

should_notify_user() {
  local user="${1:-}"
  if [[ -n "${SSH_AUTH_NOTIFY_ONLY_USERS:-}" ]]; then
    csv_contains "${SSH_AUTH_NOTIFY_ONLY_USERS}" "${user}" || return 1
  fi
  if [[ -n "${SSH_AUTH_NOTIFY_SKIP_USERS:-}" ]]; then
    csv_contains "${SSH_AUTH_NOTIFY_SKIP_USERS}" "${user}" && return 1
  fi
  return 0
}

human_pam_type() {
  case "${1:-}" in
    account) printf "Account session" ;;
    open_session) printf "Session opened" ;;
    close_session) printf "Session closed" ;;
    auth) printf "Authentication" ;;
    *) printf "%s" "${1:-Unknown}" ;;
  esac
}

human_source() {
  case "${1:-}" in
    pam) printf "PAM hook" ;;
    test) printf "Test mode" ;;
    *) printf "%s" "${1:-Unknown}" ;;
  esac
}

format_body() {
  local user="${1:-unknown}" rhost="${2:-unknown}" service="${3:-unknown}" tty="${4:-unknown}" pam_type="${5:-unknown}" shown_host="${6:-unknown}" now="${7:-unknown}" source_arg="${8:-unknown}"
  cat <<BODY
✅ New SSH login detected

👤 User: ${user}
🌐 Remote IP: ${rhost}
🖥️ Host: ${shown_host}
🔧 Service: ${service}
💻 Terminal: ${tty}
📌 Event: $(human_pam_type "${pam_type}")
🕒 Time: ${now}
🚀 Trigger: $(human_source "${source_arg}")
BODY
}

html_escape_text() {
  local text="${1:-}"
  text="${text//&/&amp;}"
  text="${text//</&lt;}"
  text="${text//>/&gt;}"
  printf "%s" "${text}"
}

format_body_html() {
  local user="${1:-unknown}" rhost="${2:-unknown}" service="${3:-unknown}" tty="${4:-unknown}" pam_type="${5:-unknown}" shown_host="${6:-unknown}" now="${7:-unknown}" source_arg="${8:-unknown}"
  cat <<BODY
✅ New SSH login detected

<pre>User      : $(html_escape_text "${user}")
Remote IP : $(html_escape_text "${rhost}")
Host      : $(html_escape_text "${shown_host}")
Service   : $(html_escape_text "${service}")
Terminal  : $(html_escape_text "${tty}")
Event     : $(html_escape_text "$(human_pam_type "${pam_type}")")
Time      : $(html_escape_text "${now}")
Trigger   : $(html_escape_text "$(human_source "${source_arg}")")</pre>
BODY
}

main() {
  load_config

  local source_arg user rhost service tty pam_type host shown_host now title body body_html
  source_arg="unknown"
  if [[ "${1:-}" == "--source" ]]; then
    source_arg="${2:-unknown}"
  fi

  user="${PAM_USER:-unknown}"
  rhost="${PAM_RHOST:-unknown}"
  service="${PAM_SERVICE:-sshd}"
  tty="${PAM_TTY:-unknown}"
  pam_type="${PAM_TYPE:-unknown}"
  host="$(hostname -f 2>/dev/null || hostname 2>/dev/null || printf unknown)"
  shown_host="${SSH_AUTH_NOTIFY_HOST_ALIAS:-${host}}"
  now="$(date -Is)"

  if ! should_notify_user "${user}"; then
    log_debug "skip user=${user}"
    exit 0
  fi

  title="🔐 SSH Login · ${shown_host}"
  body="$(format_body "${user}" "${rhost}" "${service}" "${tty}" "${pam_type}" "${shown_host}" "${now}" "${source_arg}")"
  body_html="$(format_body_html "${user}" "${rhost}" "${service}" "${tty}" "${pam_type}" "${shown_host}" "${now}" "${source_arg}")"

  if [[ -x "${SENDER}" ]]; then
    "${SENDER}" --title "${title}" --body "${body}" --body-html "${body_html}" || log_debug "send failed"
  else
    log_debug "sender not executable: ${SENDER}"
  fi
}

main "$@"
