#!/usr/bin/env bash
set -Eeuo pipefail

TITLE=""
BODY=""

while (($#)); do
  case "$1" in
    --title) TITLE="${2:-}"; shift 2 ;;
    --body) BODY="${2:-}"; shift 2 ;;
    *) printf '[ssh-auth-notify-send] unknown argument: %s\n' "$1" >&2; exit 2 ;;
  esac
done

log_debug() {
  if [[ "${SSH_AUTH_NOTIFY_DEBUG:-0}" == "1" ]]; then
    printf '[ssh-auth-notify-send] %s\n' "$*" >&2
  fi
}

urlencode() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$1"
}

valid_timeout() {
  [[ "${1:-}" =~ ^[0-9]+([.][0-9]+)?$ ]]
}

send_bark() {
  [[ -n "${BARK_URL:-}" ]] || { log_debug "BARK_URL is empty"; return 1; }
  local timeout="${SSH_AUTH_NOTIFY_TIMEOUT:-5}" url title_enc body_enc
  valid_timeout "${timeout}" || timeout="5"
  title_enc="$(urlencode "${TITLE}")"
  body_enc="$(urlencode "${BODY}")"
  url="${BARK_URL%/}/${title_enc}/${body_enc}"
  curl -fsS --max-time "${timeout}" "${url}" >/dev/null
}

send_telegram() {
  [[ -n "${TELEGRAM_BOT_TOKEN:-}" ]] || { log_debug "TELEGRAM_BOT_TOKEN is empty"; return 1; }
  [[ -n "${TELEGRAM_CHAT_ID:-}" ]] || { log_debug "TELEGRAM_CHAT_ID is empty"; return 1; }
  local timeout="${SSH_AUTH_NOTIFY_TIMEOUT:-5}" api
  valid_timeout "${timeout}" || timeout="5"
  api="https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage"
  curl -fsS --max-time "${timeout}" -X POST "${api}" \
    --data-urlencode "chat_id=${TELEGRAM_CHAT_ID}" \
    --data-urlencode "text=${TITLE}

${BODY}" \
    --data "disable_web_page_preview=true" >/dev/null
}

send_backend() {
  local backend="${1:-}"
  case "${backend}" in
    bark) send_bark ;;
    telegram) send_telegram ;;
    *) printf '[ssh-auth-notify-send] unsupported backend: %s\n' "${backend:-empty}" >&2; return 1 ;;
  esac
}

main() {
  [[ -n "${TITLE}" ]] || TITLE="SSH login"
  [[ -n "${BODY}" ]] || BODY="empty body"

  local backends old_ifs backend failures=0 sent=0
  backends="${SSH_AUTH_NOTIFY_BACKENDS:-${SSH_AUTH_NOTIFY_BACKEND:-}}"
  [[ -n "${backends}" ]] || { printf '[ssh-auth-notify-send] unsupported backend: empty\n' >&2; exit 1; }

  old_ifs="${IFS}"
  IFS=',' read -r -a backend_items <<<"${backends}"
  IFS="${old_ifs}"

  for backend in "${backend_items[@]}"; do
    backend="${backend//[[:space:]]/}"
    [[ -n "${backend}" ]] || continue
    if send_backend "${backend}"; then
      sent=1
      log_debug "sent via ${backend}"
    else
      failures=$((failures + 1))
      log_debug "send failed via ${backend}"
    fi
  done

  [[ "${sent}" -eq 1 ]] && return 0
  [[ "${failures}" -gt 0 ]] && return 1
  return 1
}

main "$@"
