#!/usr/bin/env bash
set -Eeuo pipefail

TITLE=""
BODY=""
BODY_HTML=""
SCRIPT_SOURCE="${BASH_SOURCE[0]:-${0:-.}}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_SOURCE}")" 2>/dev/null && pwd || pwd)"
CHANNEL_DIR="${SSH_AUTH_NOTIFY_CHANNEL_DIR:-${SCRIPT_DIR}/channels}"

while (($#)); do
  case "$1" in
    --title) TITLE="${2:-}"; shift 2 ;;
    --body) BODY="${2:-}"; shift 2 ;;
    --body-html) BODY_HTML="${2:-}"; shift 2 ;;
    *) printf "[ssh-auth-notify-send] unknown argument: %s\n" "$1" >&2; exit 2 ;;
  esac
done

log_debug() {
  if [[ "${SSH_AUTH_NOTIFY_DEBUG:-0}" == "1" ]]; then
    printf "[ssh-auth-notify-send] %s\n" "$*" >&2
  fi
}

valid_timeout() {
  [[ "${1:-}" =~ ^[0-9]+([.][0-9]+)?$ ]]
}

notify_timeout() {
  local timeout="${SSH_AUTH_NOTIFY_TIMEOUT:-5}"
  valid_timeout "${timeout}" || timeout="5"
  printf "%s" "${timeout}"
}

html_escape() {
  local text="${1:-}"
  text="${text//&/&amp;}"
  text="${text//</&lt;}"
  text="${text//>/&gt;}"
  printf "%s" "${text}"
}

require_vars() {
  local var
  for var in "$@"; do
    if [[ -z "${!var:-}" ]]; then
      log_debug "missing config: ${var}"
      return 1
    fi
  done
}

safe_channel_name() {
  [[ "${1:-}" =~ ^[a-z][a-z0-9_]*$ ]]
}

load_channel() {
  local channel="${1:-}" file
  safe_channel_name "${channel}" || return 1
  file="${CHANNEL_DIR}/${channel}.sh"
  [[ -r "${file}" ]] || return 1
  source "${file}"
}

channel_resolve() {
  local channel="${1:-}" fn
  for fn in "${channel}_required_vars" "${channel}_validate" "${channel}_send"; do
    declare -F "${fn}" >/dev/null || {
      printf "[ssh-auth-notify-send] channel %s missing function: %s\n" "${channel}" "${fn}" >&2
      return 1
    }
  done
  printf "%s %s %s\n" "${channel}_required_vars" "${channel}_validate" "${channel}_send"
}

send_channel() {
  local channel="${1:-}" title="${2:-}" body="${3:-}"
  local required_fn validate_fn send_fn
  load_channel "${channel}" || {
    printf "[ssh-auth-notify-send] unsupported channel: %s\n" "${channel:-empty}" >&2
    return 1
  }
  if ! read -r required_fn validate_fn send_fn <<<"$(channel_resolve "${channel}")"; then
    printf "[ssh-auth-notify-send] unsupported channel: %s\n" "${channel:-empty}" >&2
    return 1
  fi
  "${required_fn}" >/dev/null
  "${validate_fn}"
  "${send_fn}" "${title}" "${body}"
}

main() {
  [[ -n "${TITLE}" ]] || TITLE="SSH login"
  [[ -n "${BODY}" ]] || BODY="empty body"
  local backends old_ifs backend failures=0 sent=0
  backends="${SSH_AUTH_NOTIFY_BACKENDS:-${SSH_AUTH_NOTIFY_BACKEND:-}}"
  [[ -n "${backends}" ]] || { printf "[ssh-auth-notify-send] unsupported channel: empty\n" >&2; exit 1; }
  old_ifs="${IFS}"
  IFS="," read -r -a backend_items <<<"${backends}"
  IFS="${old_ifs}"
  for backend in "${backend_items[@]}"; do
    backend="${backend//[[:space:]]/}"
    [[ -n "${backend}" ]] || continue
    if send_channel "${backend}" "${TITLE}" "${BODY}"; then
      sent=1
      log_debug "sent via ${backend}"
    else
      failures=$((failures + 1))
      log_debug "send failed via ${backend}"
    fi
  done
  [[ "${sent}" -eq 1 ]] && return 0
  [[ "${failures}" -gt 0 ]] && return 1
  return 1
}

main "$@"
